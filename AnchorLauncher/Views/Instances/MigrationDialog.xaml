<Window x:Class="AnchorLauncher.Views.Instances.MigrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="Manual" Width="540" Height="548"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="MigProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="3" Background="{StaticResource Surface2Brush}" ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3"
                                        Background="{StaticResource AccentBrush}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect><DropShadowEffect Color="Black" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="Close_Click">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="34,2,34,0">
                <TextBlock Text="{Binding [mig_title], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding [mig_sub], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="12.5"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <TextBlock x:Name="StatusText" FontFamily="{StaticResource PrimaryFont}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,14,0,0" TextWrapping="Wrap"/>

                <StackPanel x:Name="ProgressPanel" Margin="0,14,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="Bar" Style="{StaticResource MigProgress}" Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="CurrentText" FontFamily="{StaticResource PrimaryFont}" FontSize="11.5"
                               Foreground="{StaticResource TextDisabledBrush}" Margin="0,8,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border x:Name="ListContainer" Background="{StaticResource Surface1Brush}" CornerRadius="8"
                        Margin="0,14,0,0" Padding="6" MaxHeight="280" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource AnchorScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl x:Name="FoundList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="2,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Detail}" FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="11" Foreground="{StaticResource TextDisabledBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="7,2" VerticalAlignment="Center"
                                                Background="{StaticResource AccentMutedBrush}" Margin="10,0,2,0">
                                            <TextBlock Text="{Binding Launcher}" FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Padding="34,16,34,22">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding [nd_close], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource GhostButtonStyle}" Height="38" Padding="18,0" Margin="0,0,10,0"
                            Click="Close_Click"/>
                    <Button x:Name="ImportButton" Content="{Binding [mig_import], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="38" Padding="20,0"
                            Visibility="Collapsed" Click="Import_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
