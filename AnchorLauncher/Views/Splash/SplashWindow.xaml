<Window x:Class="AnchorLauncher.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Width="420"
        Height="420"
        ResizeMode="NoResize">

    <!-- Root grid is fully transparent — desktop shows through the edges -->
    <Grid x:Name="RootGrid" Background="Transparent">

        <!-- Premium dark card floats on the transparent surface -->
        <Border Background="#CC0F0F13"
                CornerRadius="16"
                Padding="40,32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center">

                <!-- Anchor logo — transparent PNG, breathing ScaleTransform -->
                <Image Source="pack://application:,,,/Assets/AnchorLauncherIcon.png"
                       Width="160" Height="160"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       RenderTransformOrigin="0.5,0.5"
                       Stretch="Uniform">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" ScaleX="0.85" ScaleY="0.85"/>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <DropShadowEffect x:Name="LogoGlow" Color="#FF4500"
                                          BlurRadius="0" ShadowDepth="0" Opacity="0.85"/>
                    </Image.Effect>
                </Image>

                <!-- App name — fades in + slides up after 800ms -->
                <StackPanel x:Name="TextPanel" HorizontalAlignment="Center" Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="TextSlide" Y="10"/>
                    </StackPanel.RenderTransform>
                    <TextBlock Text="A N C H O R"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="16" FontWeight="SemiBold" Foreground="#FF4500"
                               HorizontalAlignment="Center" Margin="0,0,0,6"
                               TextOptions.TextFormattingMode="Display"
                               TextOptions.TextRenderingMode="ClearType"/>
                    <TextBlock Text="L A U N C H E R"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="10" FontWeight="Regular" Foreground="#A0A0A5"
                               HorizontalAlignment="Center"
                               TextOptions.TextFormattingMode="Display"
                               TextOptions.TextRenderingMode="ClearType"/>
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Window>
