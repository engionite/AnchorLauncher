<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         Built-in instance icons. Each key is "III_{name}"; the names are also
         listed in InstanceIconCatalog.BuiltIn for the picker. All are ImageSource
         (BitmapImage for the bundled PNGs, DrawingImage for the vector ones) so a
         single Image.Source binding renders any of them.
    ═════════════════════════════════════════════════════════════════════════ -->

    <!-- Bundled Minecraft / brand artwork -->
    <BitmapImage x:Key="III_grass"      UriSource="pack://application:,,,/Assets/minecraft_grass_block.png"/>
    <BitmapImage x:Key="III_diamond"    UriSource="pack://application:,,,/Assets/minecraft_diamond.png"/>
    <BitmapImage x:Key="III_chest"      UriSource="pack://application:,,,/Assets/minecraft_chest.png"/>
    <BitmapImage x:Key="III_crafting"   UriSource="pack://application:,,,/Assets/minecraft_crafting_table.png"/>
    <BitmapImage x:Key="III_enchanting" UriSource="pack://application:,,,/Assets/minecraft_enchanting_table.png"/>
    <BitmapImage x:Key="III_anchor"     UriSource="pack://application:,,,/Assets/AnchorLauncherIcon.png"/>

    <!-- Coloured "block" icons (gradient rounded squares) — handy for telling versions apart by colour -->
    <DrawingImage x:Key="III_gold"><DrawingImage.Drawing><GeometryDrawing>
        <GeometryDrawing.Geometry><RectangleGeometry Rect="10,10,80,80" RadiusX="18" RadiusY="18"/></GeometryDrawing.Geometry>
        <GeometryDrawing.Brush><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#F6CD5B" Offset="0"/><GradientStop Color="#D99A1F" Offset="1"/></LinearGradientBrush></GeometryDrawing.Brush>
    </GeometryDrawing></DrawingImage.Drawing></DrawingImage>

