<Window x:Class="AnchorLauncher.Views.Home.NewsDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="Manual" Width="520" Height="430"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Border CornerRadius="14" Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- drag / close -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                        Click="Close_Click">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- body -->
            <StackPanel Grid.Row="1" Margin="34,2,34,0">
                <Border HorizontalAlignment="Left" CornerRadius="5" Padding="9,3"
                        Background="{StaticResource AccentMutedBrush}">
                    <TextBlock x:Name="BadgeText" FontFamily="{StaticResource PrimaryFont}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                </Border>
                <TextBlock x:Name="TitleText" FontFamily="{StaticResource PrimaryFont}" FontSize="21" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>

                <Border Background="{StaticResource Surface1Brush}" CornerRadius="8" Margin="0,14,0,0"
                        Padding="16,13" MaxHeight="210">
                    <ScrollViewer Style="{StaticResource AnchorScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="BodyText" FontFamily="{StaticResource PrimaryFont}" FontSize="13"
                                   TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- footer -->
            <Border Grid.Row="2" Padding="34,16,34,22">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding [nd_close], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource GhostButtonStyle}" Height="38" Padding="18,0" Margin="0,0,10,0"
                            Click="Close_Click"/>
                    <Button x:Name="GitHubButton" Content="{Binding [nd_github], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource GhostButtonStyle}" Height="38" Padding="18,0" Margin="0,0,10,0"
                            Click="GitHub_Click"/>
                    <Button x:Name="ReleaseButton" Content="{Binding [nd_release], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="38" Padding="20,0"
                            Click="Release_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
