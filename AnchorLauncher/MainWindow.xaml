<Window x:Class="AnchorLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views_auth="clr-namespace:AnchorLauncher.Views.Auth"
        xmlns:conv="clr-namespace:AnchorLauncher.Converters"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MinWidth="1000" MinHeight="640"
        Width="1280" Height="780"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:SkinHeadConverter x:Key="SkinHead"/>
    </Window.Resources>

    <!-- Root border clips all content to the rounded shape; the transparent window shows through corners -->
    <Border Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="32"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource AppBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + App name -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Image Source="pack://application:,,,/Assets/AnchorLauncherIcon.png"
                           Width="28" Height="28"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Anchor Launcher"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Draggable region fills the center -->
                <Rectangle Grid.Column="1"
                           Fill="Transparent"
                           WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- Account chip + chrome buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- Java / Bedrock mode switch -->
                    <Border CornerRadius="5" Background="{StaticResource Surface1Brush}"
                            Height="22" VerticalAlignment="Center" Margin="0,0,10,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnModeJava" Content="Java"
                                    FontSize="10" FontWeight="SemiBold" Height="22" Padding="9,0"
                                    BorderThickness="0" Cursor="Hand"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Click="BtnModeJava_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnModeBedrock" Content="Bedrock"
                                    FontSize="10" FontWeight="SemiBold" Height="22" Padding="9,0"
                                    BorderThickness="0" Cursor="Hand"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Click="BtnModeBedrock_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Active account button -->
                    <Button x:Name="BtnAccount"
                            Style="{StaticResource GhostButtonStyle}"
                            Height="22"
                            Padding="10,0"
                            MinWidth="68"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnAccount_Click"
                            ToolTip="Manage accounts">
                        <TextBlock x:Name="BtnAccountText"
                                   Text="Sign In"
                                   FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Margin="0,8,4,8"
                            Background="{StaticResource Surface2Brush}" Opacity="0.5"/>

                    <!-- ═══ Window chrome buttons (46×32 each, small fixed icons) ═══ -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Top" Height="32"
                                WindowChrome.IsHitTestVisibleInChrome="True">

                        <!-- Minimize: a plain 10×1 line (no geometry to overflow) -->
                        <Button x:Name="BtnMinimize" Width="46" Height="32"
                                Style="{StaticResource ChromeButtonStyle}"
                                Click="BtnMinimize_Click" ToolTip="Minimize">
                            <Rectangle Width="10" Height="1" Fill="#C8C8CE"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Maximize / Restore: square outline scaled to fit 10×10 -->
                        <Button x:Name="BtnMaximize" Width="46" Height="32"
                                Style="{StaticResource ChromeButtonStyle}"
                                Click="BtnMaximize_Click" ToolTip="Maximize">
                            <Path x:Name="MaximizePath" Data="M 0,0 H 10 V 10 H 0 Z"
                                  Stroke="#C8C8CE" StrokeThickness="1" Fill="Transparent"
                                  Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Close: X scaled to fit 10×10 -->
                        <Button x:Name="BtnClose" Width="46" Height="32"
                                Style="{StaticResource ChromeCloseButtonStyle}"
                                Click="BtnClose_Click" ToolTip="Close">
                            <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                  Stroke="#FFFFFF" StrokeThickness="1"
                                  Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ═══════════ MAIN BODY ═══════════ -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- Session-expired warning banner (hidden by default) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Sidebar + content area -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <!-- Left sidebar -->
                    <ColumnDefinition x:Name="SidebarColumn" Width="64"/>
                    <!-- Content area -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Session-expired warning banner ─── -->
                <Border x:Name="WarningBanner"
                        Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Background="#26180A"
                        Visibility="Collapsed">
                    <Grid Margin="14,0" Height="32">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M 12,2 L 22,20 H 2 Z M 12,9 V 13 M 12,16 V 17"
                                  Fill="{StaticResource WarningBrush}"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Session expired — sign in again to launch games."
                                       FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11"
                                       Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="Sign In Again"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="22" Padding="8,0" FontSize="10"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="BtnSignInAgain_Click"/>
                    </Grid>
                </Border>

                <!-- Sidebar -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="{DynamicResource AppBackgroundBrush}">
                    <Grid>
                        <!-- Drop shadow on right edge for depth -->
                        <Border HorizontalAlignment="Right" Width="1"
                                Background="{StaticResource Surface2Brush}" Opacity="0.5"/>

                        <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">
                            <!-- Home -->
                            <Grid Margin="0,3">
                                <Border x:Name="NavHomeBar" Width="3" Height="22" CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                                    <Border.RenderTransform><ScaleTransform x:Name="NavHomeBarScale" ScaleY="1"/></Border.RenderTransform>
                                </Border>
                                <Button x:Name="NavHome" Style="{StaticResource IconButtonStyle}"
                                        Width="44" Height="44" HorizontalAlignment="Center"
                                        ToolTip="{Binding [home], Source={x:Static loc:Loc.I}}" Click="NavHome_Click">
                                    <Path Data="M3,11 L12,3 L21,11 M5,9.5 V20 A0.5,0.5 0 0 0 5.5,20.5 H9.5 V14.5 H14.5 V20.5 H18.5 A0.5,0.5 0 0 0 19,20 V9.5"
                                          Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.7"
                                          Fill="Transparent" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </Grid>

                            <!-- Instances -->
                            <Grid Margin="0,3">
                                <Border x:Name="NavInstancesBar" Width="3" Height="22" CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                                    <Border.RenderTransform><ScaleTransform x:Name="NavInstancesBarScale" ScaleY="1"/></Border.RenderTransform>
                                </Border>
                                <Button x:Name="NavInstances" Style="{StaticResource IconButtonStyle}"
                                        Width="44" Height="44" HorizontalAlignment="Center"
                                        ToolTip="{Binding [instances], Source={x:Static loc:Loc.I}}" Click="NavInstances_Click">
                                    <Path Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,14 H21 V21 H14 Z"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </Grid>

                            <!-- Downloads / Marketplace -->
                            <Grid Margin="0,3">
                                <Border x:Name="NavDownloadsBar" Width="3" Height="22" CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Button x:Name="NavDownloads" Style="{StaticResource IconButtonStyle}"
                                        Width="44" Height="44" HorizontalAlignment="Center"
                                        ToolTip="{Binding [marketplace], Source={x:Static loc:Loc.I}}" Click="NavDownloads_Click">
                                    <Path Data="M12,3 V13 M7.5,9 L12,13.5 L16.5,9 M4,15 V19 A1,1 0 0 0 5,20 H19 A1,1 0 0 0 20,19 V15"
                                          Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.7"
                                          Fill="Transparent" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </Grid>

                            <!-- Skins -->
                            <Grid Margin="0,3">
                                <Border x:Name="NavSkinsBar" Width="3" Height="22" CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Button x:Name="NavSkins" Style="{StaticResource IconButtonStyle}"
                                        Width="44" Height="44" HorizontalAlignment="Center"
                                        ToolTip="{Binding [skins], Source={x:Static loc:Loc.I}}" Click="NavSkins_Click">
                                    <Path Data="M12,3 A4,4 0 1 1 12,11 A4,4 0 1 1 12,3 Z M4.5,21 C4.5,16.5 8,14 12,14 C16,14 19.5,16.5 19.5,21 Z"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Settings + active account pinned to bottom -->
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,14">
                            <!-- Active account skin head — click to open the account overlay -->
                            <Button Style="{StaticResource IconButtonStyle}" Margin="0,3,0,8" Padding="0"
                                    Width="44" Height="44" HorizontalAlignment="Center"
                                    Click="BtnAccount_Click"
                                    ToolTip="{Binding AccountVM.ActiveAccount.Username, RelativeSource={RelativeSource AncestorType=Window}, TargetNullValue='Sign In', FallbackValue='Sign In'}">
                                <Border Width="30" Height="30" CornerRadius="8" ClipToBounds="True" Background="#232329">
                                    <Image Source="{Binding AccountVM.ActiveAccount, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SkinHead}}"
                                           Width="30" Height="30" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                            </Button>

                            <Grid Margin="0,3">
                                <Border x:Name="NavSettingsBar" Width="3" Height="22" CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentBrush}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Button x:Name="NavSettings" Style="{StaticResource IconButtonStyle}"
                                        Width="44" Height="44" HorizontalAlignment="Center"
                                        ToolTip="{Binding [settings], Source={x:Static loc:Loc.I}}" Click="NavSettings_Click">
                                    <Path Data="M12,2 L13.5,5.5 L17.5,4 L18.5,7.5 L22,9 L19.5,12 L22,15 L18.5,16.5 L17.5,20 L13.5,18.5 L12,22 L10.5,18.5 L6.5,20 L5.5,16.5 L2,15 L4.5,12 L2,9 L5.5,7.5 L6.5,4 L10.5,5.5 Z M12,9 A3,3 0 1 0 12,15 A3,3 0 1 0 12,9 Z"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Width="18" Height="18" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content frame with drop shadow on the left edge -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="{DynamicResource AppBackgroundBrush}">
                    <Border.Effect>
                        <DropShadowEffect Direction="180" BlurRadius="15" Opacity="0.2" ShadowDepth="0"/>
                    </Border.Effect>
                    <Frame x:Name="ContentFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"/>
                </Border>

                <!-- ─── Account manager overlay ─── -->
                <!-- Starts translated off-screen (X=340). Toggle() slides it in. -->
                <views_auth:AccountManagerOverlay
                    x:Name="AccountOverlay"
                    Grid.Row="0" Grid.RowSpan="2"
                    Grid.Column="0" Grid.ColumnSpan="2"
                    Width="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Panel.ZIndex="100"/>
            </Grid>
        </Grid>
    </Border>
</Window>
