<Page x:Class="AnchorLauncher.Views.Instances.SkinsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:AnchorLauncher.Converters"
      xmlns:vm="clr-namespace:AnchorLauncher.ViewModels"
      xmlns:sk="clr-namespace:AnchorLauncher.Views.Skins"
      xmlns:mk="clr-namespace:AnchorLauncher.Models.Skins"
      xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
      Background="{StaticResource AppBackgroundBrush}"
      Title="Skins"
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType">

    <Page.DataContext>
        <vm:SkinsViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter          x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:CountToVisibilityConverter       x:Key="CountToVis"/>
        <conv:SkinFileHeadConverter            x:Key="SkinFileHead"/>
    </Page.Resources>

    <Grid>
        <!-- Bedrock mode: this page hosts the Bedrock panel instead -->
        <ContentControl x:Name="BedrockHost" Visibility="Collapsed" Margin="32,28,32,28"/>

        <Grid x:Name="SkinsContent" Margin="32,28,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="{Binding [skins], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSize2XL}"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding [skins_sub], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeMD}"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Content="{Binding [refresh], Source={x:Static loc:Loc.I}}" Style="{StaticResource GhostButtonStyle}"
                            Height="36" Padding="16,0" Margin="0,0,10,0"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="{Binding [change_skin], Source={x:Static loc:Loc.I}}" Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Padding="20,0" Click="BtnChangeSkin_Click"/>
                </StackPanel>
            </Grid>

            <!-- Body: 3D viewer (left) + rail (right) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── 3D viewer ── -->
                <Border Grid.Column="0" CornerRadius="12" ClipToBounds="True"
                        BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
                    <Grid>
                        <sk:SkinViewer3D x:Name="Viewer"/>
                        <TextBlock Text="{Binding [drag_rotate], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#80FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   Margin="0,0,0,14"/>
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
                                CornerRadius="6" Padding="10,5" Background="#A618181C">
                            <StackPanel>
                                <TextBlock Text="{Binding Username}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding AccountLabel}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Right rail ── -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource AnchorScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <!-- Skin marketplace -->
                        <TextBlock Text="{Binding [skin_marketplace], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,12"/>
                        <ItemsControl ItemsSource="{Binding MarketplaceSkins}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type mk:SkinMarketItem}">
                                    <Border Background="{StaticResource Surface1Brush}" CornerRadius="10"
                                            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1"
                                            Margin="0,0,12,12" Padding="10,12">
                                        <StackPanel>
                                            <Border Width="56" Height="56" CornerRadius="8" ClipToBounds="True"
                                                    Background="#232329" HorizontalAlignment="Center">
                                                <Image Source="{Binding HeadUrl}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" Margin="0,8,0,8"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Content="{Binding [apply], Source={x:Static loc:Loc.I}}" Style="{StaticResource GhostButtonStyle}"
                                                    Height="28" Padding="0" FontSize="11"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.ApplyMarketplaceSkinCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Skin history -->
                        <TextBlock Text="{Binding [skin_history], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,12"/>
                        <ItemsControl ItemsSource="{Binding History}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource IconButtonStyle}" Padding="0"
                                            Margin="0,0,10,10" ToolTip="Re-apply this skin"
                                            Command="{Binding DataContext.ApplyHistoryCommand,
                                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <Border Background="{StaticResource Surface1Brush}" CornerRadius="8"
                                                BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1"
                                                Padding="8">
                                            <Image Source="{Binding Converter={StaticResource SkinFileHead}}"
                                                   Width="48" Height="48"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty history hint -->
                        <TextBlock Text="{Binding [skins_no_history], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="12"
                                   Foreground="{StaticResource TextDisabledBrush}"
                                   Visibility="{Binding History.Count, Converter={StaticResource CountToVis}}"/>

                        <!-- Status / busy -->
                        <ProgressBar Style="{StaticResource AnchorProgressBarStyle}" Width="180" Height="3"
                                     IsIndeterminate="True" HorizontalAlignment="Left" Margin="0,14,0,8"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
