<Window x:Class="AnchorSetup.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorSetup.Localization"
        Title="Uninstall Anchor Launcher"
        Width="500" Height="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Icon="/Assets/AnchorLauncherIcon.png"
        FontFamily="{StaticResource UiFont}" UseLayoutRounding="True">

    <Border Margin="16" CornerRadius="16" Background="{StaticResource BgBrush}" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="36" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- chrome -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Chrome_MouseDown">
                <Button HorizontalAlignment="Right" Margin="0,4,8,0" Style="{StaticResource CloseButton}"
                        Click="Cancel_Click" Content="&#xE8BB;" />
            </Border>

            <!-- body -->
            <StackPanel Grid.Row="1" Margin="40,4,40,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/AnchorLauncherIcon.png" Width="46" Height="46"
                           RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding [un_title], Source={x:Static loc:SetupLoc.I}}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="14,0,0,0" />
                </StackPanel>

                <!-- prompt state -->
                <StackPanel x:Name="PromptPanel" Margin="0,18,0,0">
                    <TextBlock Text="{Binding [un_body], Source={x:Static loc:SetupLoc.I}}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13.5" TextWrapping="Wrap"
                               LineHeight="20" />
                    <CheckBox x:Name="DeleteDataCheck" Style="{StaticResource ModernCheck}" Margin="0,20,0,0"
                              Content="{Binding [un_keepdata], Source={x:Static loc:SetupLoc.I}}" />
                </StackPanel>

                <!-- removing / done state -->
                <StackPanel x:Name="StatusPanel" Margin="0,20,0,0" Visibility="Collapsed">
                    <ProgressBar Style="{StaticResource ModernProgress}" IsIndeterminate="True" Width="360"
                                 HorizontalAlignment="Left" />
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13.5"
                               Margin="0,14,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- footer -->
            <Border Grid.Row="2" BorderBrush="{StaticResource StrokeSoftBrush}" BorderThickness="0,1,0,0">
                <StackPanel x:Name="FooterPanel" Orientation="Horizontal" HorizontalAlignment="Right" Margin="28,16,28,20">
                    <Button Style="{StaticResource GhostButton}" Margin="0,0,12,0" Click="Cancel_Click"
                            Content="{Binding [btn_cancel], Source={x:Static loc:SetupLoc.I}}" />
                    <Button Style="{StaticResource PrimaryButton}" MinWidth="120" Click="Remove_Click"
                            Content="{Binding [un_remove], Source={x:Static loc:SetupLoc.I}}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
