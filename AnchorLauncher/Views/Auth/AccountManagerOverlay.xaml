<UserControl x:Class="AnchorLauncher.Views.Auth.AccountManagerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AnchorLauncher.Views.Auth"
             xmlns:conv="clr-namespace:AnchorLauncher.Converters"
             xmlns:auth="clr-namespace:AnchorLauncher.Models.Auth"
             xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <UserControl.Resources>
        <conv:FirstLetterConverter       x:Key="FirstLetter"/>
        <conv:IsActiveAccountConverter   x:Key="IsActiveAccount"/>
        <conv:AccountTypeToColorConverter x:Key="TypeToColor"/>
        <conv:AccountTypeToStringConverter x:Key="AccountTypeName"/>
        <conv:SkinHeadConverter          x:Key="SkinHead"/>
        <BooleanToVisibilityConverter    x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Starts at X=340 (off-screen right); Toggle() animates to X=0 -->
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" X="340"/>
    </UserControl.RenderTransform>

    <!-- Root panel — solid background prevents bleed-through -->
    <Border Background="#18181C"
            BorderBrush="#232329"
            BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect Direction="270" BlurRadius="24" ShadowDepth="8" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>    <!-- Header -->
                <RowDefinition Height="*"/>     <!-- Account list -->
                <RowDefinition Height="Auto"/>  <!-- Device code panel (conditional) -->
                <RowDefinition Height="Auto"/>  <!-- Footer add-buttons -->
                <RowDefinition Height="Auto"/>  <!-- Busy bar -->
                <RowDefinition Height="Auto"/>  <!-- Status text -->
            </Grid.RowDefinitions>

            <!-- ══ Header ══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="16,0,8,0">
                <TextBlock Text="{Binding [acc_title], Source={x:Static loc:Loc.I}}"
                           FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#55555A"
                           VerticalAlignment="Center"/>

                <Button x:Name="BtnClose"
                        Style="{StaticResource IconButtonStyle}"
                        Width="28" Height="28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="BtnClose_Click"
                        ToolTip="Close">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5"
                          StrokeEndLineCap="Round"
                          Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- ══ Account list ════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource AnchorScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ItemsControl x:Name="AccountsList" ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Row with accent left-border for the active account -->
                            <Border Margin="0,0,0,1" Height="60" Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush"    Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource IsActiveAccount}">
                                                        <Binding/>
                                                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type local:AccountManagerOverlay}}"
                                                                 Path="DataContext.ActiveAccount"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid Margin="12,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>  <!-- Avatar -->
                                        <ColumnDefinition Width="*"/>     <!-- Name + badge -->
                                        <ColumnDefinition Width="Auto"/>  <!-- Set active -->
                                        <ColumnDefinition Width="Auto"/>  <!-- Remove -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar: the player's actual skin head (Steve fallback in the converter) -->
                                    <Border Grid.Column="0"
                                            Width="32" Height="32" CornerRadius="8" ClipToBounds="True"
                                            VerticalAlignment="Center" Margin="0,0,10,0"
                                            Background="#232329">
                                        <Image Source="{Binding Converter={StaticResource SkinHead}}"
                                               Width="32" Height="32" Stretch="Fill"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>

                                    <!-- Username + type label -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Username}"
                                                   FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="{Binding AccountType, Converter={StaticResource AccountTypeName}}"
                                                   FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                                   FontSize="10" Foreground="#55555A" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Set Active button + transient green success flash -->
                                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <Button Tag="setActiveBtn"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Height="26" Padding="8,0"
                                                FontSize="11"
                                                Content="{Binding [acc_setactive], Source={x:Static loc:Loc.I}}"
                                                Command="{Binding DataContext.SetActiveAccountCommand,
                                                                  RelativeSource={RelativeSource AncestorType={x:Type local:AccountManagerOverlay}}}"
                                                CommandParameter="{Binding}"/>
                                        <Border Tag="setActiveFlash" Visibility="Collapsed"
                                                Height="26" CornerRadius="6" Padding="10,0"
                                                Background="#10B981">
                                            <TextBlock Text="✓ Active"
                                                       Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Remove button -->
                                    <Button Grid.Column="3"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="28" Height="28"
                                            VerticalAlignment="Center"
                                            ToolTip="Remove account"
                                            Command="{Binding DataContext.RemoveAccountCommand,
                                                              RelativeSource={RelativeSource AncestorType={x:Type local:AccountManagerOverlay}}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="M 8,8 L 20,20 M 20,8 L 8,20"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="1.5"
                                              StrokeEndLineCap="Round"
                                              Width="12" Height="12" Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ══ Device code panel (Microsoft sign-in) ══════════════════ -->
            <Border Grid.Row="2"
                    Visibility="{Binding IsDeviceCodeVisible, Converter={StaticResource BoolToVis}}"
                    Background="#1C1C20"
                    CornerRadius="8"
                    Margin="8,4"
                    Padding="16,14">
                <StackPanel>
                    <TextBlock Text="{Binding [lg_ms_title], Source={x:Static loc:Loc.I}}"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#FFFFFF" Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding [lg_ms_url], Source={x:Static loc:Loc.I}}"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="11" Foreground="#A0A0A5" Margin="0,0,0,4"/>

                    <!-- URL chip -->
                    <Border Background="#232329" CornerRadius="4" Padding="8,5" Margin="0,0,0,10">
                        <TextBlock Text="{Binding DeviceCodeUrl}"
                                   FontFamily="Consolas, Courier New"
                                   FontSize="11" Foreground="#A0A0A5"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="{Binding [lg_ms_code], Source={x:Static loc:Loc.I}}"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="11" Foreground="#A0A0A5" Margin="0,0,0,6"/>

                    <!-- Code display -->
                    <Border Background="#232329" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                        <TextBlock Text="{Binding DeviceCode}"
                                   FontFamily="Consolas, Courier New"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <Button Content="{Binding [lg_open_browser], Source={x:Static loc:Loc.I}}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="30" Padding="12,0" FontSize="11"
                                Margin="0,0,6,0"
                                Command="{Binding OpenDeviceCodeUrlCommand}"/>
                        <Button Content="{Binding [lg_copy_code], Source={x:Static loc:Loc.I}}"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="30" Padding="12,0" FontSize="11"
                                Margin="0,0,6,0"
                                Command="{Binding CopyDeviceCodeCommand}"/>
                        <Button Content="{Binding [ci_cancel], Source={x:Static loc:Loc.I}}"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="30" Padding="12,0" FontSize="11"
                                Command="{Binding CancelAuthCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══ Footer: add-account buttons ════════════════════════════ -->
            <StackPanel Grid.Row="3" Margin="8,6,8,0">
                <Button Content="{Binding [acc_addms], Source={x:Static loc:Loc.I}}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="36" Margin="0,0,0,6"
                        FontSize="12"
                        Command="{Binding AddMicrosoftAccountCommand}"/>
                <Button Content="{Binding [acc_addely], Source={x:Static loc:Loc.I}}"
                        Style="{StaticResource GhostButtonStyle}"
                        Height="36" Margin="0,0,0,2"
                        FontSize="12"
                        Click="BtnAddEly_Click"/>
            </StackPanel>

            <!-- ══ Busy progress bar ═══════════════════════════════════════ -->
            <ProgressBar Grid.Row="4"
                         Style="{StaticResource AnchorProgressBarStyle}"
                         IsIndeterminate="True"
                         Height="2"
                         Margin="8,4"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

            <!-- ══ Status text ══════════════════════════════════════════════ -->
            <TextBlock Grid.Row="5"
                       Text="{Binding StatusMessage}"
                       FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                       FontSize="11"
                       Foreground="#55555A"
                       Margin="12,2,12,12"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</UserControl>
