<Window x:Class="AnchorLauncher.Views.Instances.VersionSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:AnchorLauncher.Models.Instances"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0F0F13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="560" Height="640"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="VersionItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Surface2Brush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="46" Background="{StaticResource Surface1Brush}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock Text="Switch Version"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding InstanceName}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0"/>
                    <Border CornerRadius="4" Padding="7,2" Margin="10,0,0,0"
                            Background="{StaticResource Surface2Brush}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentVersion}" FontSize="10"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                        Click="BtnCancel_Click" ToolTip="Cancel">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="13" Height="13" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="22,18,22,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="NEW MINECRAFT VERSION (RELEASES)"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,0,0,7"/>

                <Border Grid.Row="1" Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" CornerRadius="6">
                    <ListBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"
                             ItemContainerStyle="{StaticResource VersionItem}"
                             Background="Transparent" BorderThickness="0" Margin="4"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource AnchorScrollBarStyle}"/>
                        </ListBox.Resources>
                    </ListBox>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,10">
                    <Button Content="Analyze Compatibility" Style="{StaticResource GhostButtonStyle}"
                            Height="34" Padding="16,0" HorizontalAlignment="Left"
                            Command="{Binding AnalyzeCommand}"/>
                    <TextBlock Text="{Binding Summary}" HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="12"
                               Foreground="{StaticResource AccentBrush}"/>
                </Grid>

                <!-- Plan -->
                <Border Grid.Row="3" Background="{StaticResource Surface1Brush}" CornerRadius="8"
                        Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer Style="{StaticResource AnchorScrollViewerStyle}" Margin="6">
                        <ItemsControl ItemsSource="{Binding Plan}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type mi:SwitchPlanEntry}">
                                    <Grid Margin="8,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="7" Height="7" CornerRadius="4"
                                                VerticalAlignment="Top" Margin="0,5,9,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="{x:Static mi:SwitchModStatus.UpdateAvailable}">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="{x:Static mi:SwitchModStatus.Unknown}">
                                                            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontFamily="{StaticResource PrimaryFont}" FontSize="12.5"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource Surface1Brush}" Padding="22,12" Margin="0,12,0,0">
                <Grid>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Width="230"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Style="{StaticResource AnchorProgressBarStyle}"
                                     Minimum="0" Maximum="100" Value="{Binding Progress}" Height="3"/>
                        <TextBlock Text="{Binding ProgressStatus}" Margin="0,5,0,0"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" HorizontalAlignment="Left" VerticalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="11"
                               Foreground="{StaticResource ErrorBrush}" MaxWidth="250" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource GhostButtonStyle}"
                                Height="38" Padding="18,0" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                        <Button Content="Switch Version" Style="{StaticResource PrimaryButtonStyle}"
                                Height="38" Padding="24,0"
                                IsEnabled="{Binding HasPlan}"
                                Command="{Binding SwitchCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
