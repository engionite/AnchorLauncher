<Window x:Class="AnchorLauncher.Views.Instances.CreateInstanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AnchorLauncher.Converters"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0F0F13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="540" Height="740"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToBooleanConverter  x:Key="EnumToBool"/>

        <!-- Filter chip (ToggleButton) -->
        <Style x:Key="FilterChip" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg" CornerRadius="13" Padding="12,5"
                                Background="{StaticResource Surface1Brush}"
                                BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentMutedBrush}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark radio button -->
        <Style x:Key="LoaderRadio" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Margin"     Value="0,0,18,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,7,0">
                                <Ellipse x:Name="outer" Stroke="{StaticResource Surface2Brush}" StrokeThickness="1.5"/>
                                <Ellipse x:Name="dot" Width="8" Height="8" Fill="{StaticResource AccentBrush}" Opacity="0"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="dot"   Property="Opacity" Value="1"/>
                                <Setter TargetName="outer" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Version list item -->
        <Style x:Key="VersionItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Surface2Brush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- title bar -->
                <RowDefinition Height="*"/>     <!-- body -->
                <RowDefinition Height="Auto"/>  <!-- footer -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="46" Background="{StaticResource Surface1Brush}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="{Binding [ci_title], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="18,0,0,0"/>
                <Button Style="{StaticResource IconButtonStyle}"
                        Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                        Click="BtnCancel_Click" ToolTip="Cancel">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21"
                          Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"
                          StrokeEndLineCap="Round" Width="13" Height="13" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" Style="{StaticResource AnchorScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,16">

                <!-- Name -->
                <TextBlock Text="{Binding [ci_name], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,0,0,7"/>
                <TextBox Style="{StaticResource AnchorTextBoxStyle}"
                         Height="38"
                         Foreground="#FFFFFF"
                         CaretBrush="#FFFFFF"
                         Text="{Binding InstanceName, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Version -->
                <TextBlock Text="{Binding [ci_mcver], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,18,0,7"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ToggleButton Style="{StaticResource FilterChip}" Content="{Binding [ci_releases], Source={x:Static loc:Loc.I}}"  IsChecked="{Binding ShowReleases}"/>
                    <ToggleButton Style="{StaticResource FilterChip}" Content="{Binding [ci_snapshots], Source={x:Static loc:Loc.I}}" IsChecked="{Binding ShowSnapshots}"/>
                    <ToggleButton Style="{StaticResource FilterChip}" Content="{Binding [ci_beta], Source={x:Static loc:Loc.I}}"      IsChecked="{Binding ShowBeta}"/>
                    <ToggleButton Style="{StaticResource FilterChip}" Content="{Binding [ci_alpha], Source={x:Static loc:Loc.I}}"     IsChecked="{Binding ShowAlpha}"/>
                </StackPanel>

                <Border Background="{StaticResource Surface1Brush}"
                        BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1"
                        CornerRadius="6" Height="196">
                    <Grid>
                        <ListBox ItemsSource="{Binding Versions}"
                                 SelectedItem="{Binding SelectedVersion}"
                                 ItemContainerStyle="{StaticResource VersionItem}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Id}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="12.5"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Type}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextDisabledBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Loading overlay -->
                        <Border Background="#660F0F13"
                                Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ProgressBar Style="{StaticResource AnchorProgressBarStyle}"
                                             IsIndeterminate="True" Width="140" Height="3"/>
                                <TextBlock Text="Loading versions…"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Mod loader -->
                <TextBlock Text="{Binding [ci_loader], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,18,0,9"/>
                <WrapPanel>
                    <RadioButton Style="{StaticResource LoaderRadio}" GroupName="loader" Content="{Binding [ci_vanilla], Source={x:Static loc:Loc.I}}"
                                 IsChecked="{Binding SelectedLoader, Converter={StaticResource EnumToBool}, ConverterParameter=Vanilla}"/>
                    <RadioButton Style="{StaticResource LoaderRadio}" GroupName="loader" Content="Fabric"
                                 IsChecked="{Binding SelectedLoader, Converter={StaticResource EnumToBool}, ConverterParameter=Fabric}"/>
                    <RadioButton Style="{StaticResource LoaderRadio}" GroupName="loader" Content="Forge"
                                 IsChecked="{Binding SelectedLoader, Converter={StaticResource EnumToBool}, ConverterParameter=Forge}"/>
                    <RadioButton Style="{StaticResource LoaderRadio}" GroupName="loader" Content="NeoForge"
                                 IsChecked="{Binding SelectedLoader, Converter={StaticResource EnumToBool}, ConverterParameter=NeoForge}"/>
                    <RadioButton Style="{StaticResource LoaderRadio}" GroupName="loader" Content="Quilt"
                                 IsChecked="{Binding SelectedLoader, Converter={StaticResource EnumToBool}, ConverterParameter=Quilt}"/>
                </WrapPanel>

                <!-- Loader version (only for non-Vanilla) -->
                <StackPanel Visibility="{Binding ShowLoaderVersions, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding [ci_loaderver], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDisabledBrush}" Margin="0,4,0,7"/>
                    <Border Background="{StaticResource Surface1Brush}"
                            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1"
                            CornerRadius="6" Height="116">
                        <Grid>
                            <ListBox ItemsSource="{Binding LoaderVersions}"
                                     SelectedItem="{Binding SelectedLoaderVersion}"
                                     ItemContainerStyle="{StaticResource VersionItem}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Margin="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="12.5"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Loading overlay -->
                            <Border Background="#660F0F13"
                                    Visibility="{Binding IsLoadingLoaderVersions, Converter={StaticResource BoolToVis}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ProgressBar Style="{StaticResource AnchorProgressBarStyle}"
                                                 IsIndeterminate="True" Width="120" Height="3"/>
                                    <TextBlock Text="{Binding [ci_loadingloaders], Source={x:Static loc:Loc.I}}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Copy game settings from another instance (optional) -->
                <TextBlock Text="{Binding [ci_copysettings], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,12,0,7"/>
                <ComboBox Style="{StaticResource AnchorComboBoxStyle}"
                          ItemContainerStyle="{StaticResource AnchorComboBoxItemStyle}"
                          ItemsSource="{Binding ExistingInstances}"
                          SelectedItem="{Binding CopySettingsFrom}"
                          DisplayMemberPath="Name"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="11" Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource Surface1Brush}" Padding="24,12">
                <Grid>
                    <!-- Progress (during create) -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                                Width="240"
                                Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Style="{StaticResource AnchorProgressBarStyle}"
                                     Minimum="0" Maximum="100" Value="{Binding Progress}"
                                     Height="3"/>
                        <TextBlock Text="{Binding ProgressStatus}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding [ci_cancel], Source={x:Static loc:Loc.I}}"
                                Style="{StaticResource GhostButtonStyle}"
                                Height="38" Padding="20,0" Margin="0,0,10,0"
                                Click="BtnCancel_Click"/>
                        <Button Content="{Binding [ci_create], Source={x:Static loc:Loc.I}}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38" Padding="28,0"
                                Command="{Binding CreateCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
