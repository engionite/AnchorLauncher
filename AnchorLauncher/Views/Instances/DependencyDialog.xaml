<Window x:Class="AnchorLauncher.Views.Instances.DependencyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        SizeToContent="Height" Width="440" ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Border Background="#18181C" BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1"
            CornerRadius="8" Margin="14" MouseLeftButtonDown="Root_MouseDown">
        <Border.Effect><DropShadowEffect BlurRadius="22" ShadowDepth="4" Direction="270" Opacity="0.55"/></Border.Effect>

        <StackPanel Margin="24,22,24,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <!-- package / module glyph in accent -->
                <Path Data="M3,7 L12,3 L21,7 L21,17 L12,21 L3,17 Z M3,7 L12,11 L21,7 M12,11 L12,21"
                      Stroke="{StaticResource AccentBrush}" StrokeThickness="1.6"
                      StrokeLineJoin="Round" StrokeEndLineCap="Round"
                      Width="22" Height="22" Stretch="Uniform"
                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding [dep_title], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="SubjectText"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding [dep_intro], Source={x:Static loc:Loc.I}}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,6,0,10"/>

            <ItemsControl x:Name="DepList" Margin="0,0,0,18">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}"
                                     VerticalAlignment="Center" Margin="2,0,10,0"/>
                            <TextBlock Text="{Binding}" FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding [dep_skip], Source={x:Static loc:Loc.I}}"
                        Style="{StaticResource GhostButtonStyle}" Height="36" Padding="18,0" Margin="0,0,10,0"
                        Click="Skip_Click"/>
                <Button Content="{Binding [dep_install], Source={x:Static loc:Loc.I}}"
                        Style="{StaticResource PrimaryButtonStyle}" Height="36" Padding="22,0"
                        Click="Install_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
