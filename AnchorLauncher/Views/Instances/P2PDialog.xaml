<Window x:Class="AnchorLauncher.Views.Instances.P2PDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="Manual" Width="490" Height="430"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Border CornerRadius="14" Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect><DropShadowEffect Color="Black" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="Close_Click">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="34,2,34,0">
                <TextBlock Text="{Binding [p2p_title], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding [p2p_intro], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="12.5" LineHeight="18"
                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [p2p_portlabel], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                    <Border Background="{StaticResource Surface1Brush}" BorderBrush="{StaticResource Surface2Brush}"
                            BorderThickness="1" CornerRadius="6">
                        <TextBox x:Name="PortBox" Width="110" Background="Transparent" BorderThickness="0"
                                 Padding="10,6" MaxLength="5" Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="14"/>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="StatusText" FontFamily="{StaticResource PrimaryFont}" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,14,0,0" TextWrapping="Wrap"/>

                <Border x:Name="AddressPanel" Background="{StaticResource Surface1Brush}" CornerRadius="8"
                        Margin="0,12,0,0" Padding="14,12" Visibility="Collapsed">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AddressText" Grid.Column="0" IsReadOnly="True" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource AccentHoverBrush}"
                                     FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="CopyButton" Grid.Column="1" Content="{Binding [p2p_copy], Source={x:Static loc:Loc.I}}"
                                    Style="{StaticResource GhostButtonStyle}" Height="32" Padding="14,0" Click="Copy_Click"/>
                        </Grid>
                        <TextBlock Text="{Binding [p2p_join], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="11.5"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Padding="34,16,34,22">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding [nd_close], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource GhostButtonStyle}" Height="38" Padding="18,0" Margin="0,0,10,0"
                            Click="Close_Click"/>
                    <Button x:Name="HostButton" Content="{Binding [p2p_host], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="38" Padding="22,0"
                            Click="Host_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
