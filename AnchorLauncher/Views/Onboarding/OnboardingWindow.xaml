<Window x:Class="AnchorLauncher.Views.Onboarding.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0F0F13"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="780"
        ResizeMode="NoResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ JAVA EDITION CARD ══════════════ -->
        <Border x:Name="JavaCard"
                Grid.Column="0"
                ClipToBounds="True"
                Cursor="Hand"
                RenderTransformOrigin="0.5,0.5"
                MouseEnter="JavaCard_MouseEnter"
                MouseLeave="AnyCard_MouseLeave"
                MouseLeftButtonUp="JavaCard_Click">
            <Border.RenderTransform>
                <ScaleTransform x:Name="JavaCardScale"/>
            </Border.RenderTransform>

            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/wallpaper_java.png"
                            Stretch="UniformToFill"
                            AlignmentX="Center"
                            AlignmentY="Center"/>
            </Border.Background>

            <Grid>
                <!-- Atmospheric noise overlay -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0.0"/>
                            <GradientStop Color="#CC0F0F13" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Edition label badge -->
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="40,36,0,0"
                        Background="#33FF4500"
                        BorderBrush="#55FF4500"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4">
                    <TextBlock Text="J A V A  E D I T I O N"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#FF4500"/>
                </Border>

                <!-- Main content pinned to bottom-left -->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Margin="40,0,40,56">

                    <TextBlock Text="Java Edition"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Full mod support. Shaders. Custom instances.&#x0a;The original Minecraft experience."
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="14"
                               FontWeight="Regular"
                               Foreground="#A0A0A5"
                               TextWrapping="Wrap"
                               Margin="0,0,0,28"/>

                    <!-- Feature chips -->
                    <WrapPanel Margin="0,0,0,32">
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="Fabric / Forge / Quilt" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="OptiFine &amp; Shaders" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="Modrinth / CurseForge" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                    </WrapPanel>

                    <Button x:Name="BtnSelectJava"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Select Java Edition"
                            Width="220"
                            Height="44"
                            HorizontalAlignment="Left"
                            FontSize="14"
                            Click="JavaCard_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Vertical divider -->
        <Border Grid.Column="0"
                Width="1"
                HorizontalAlignment="Right"
                Background="#33FFFFFF"
                IsHitTestVisible="False"/>

        <!-- ══════════════ BEDROCK EDITION CARD ══════════════ -->
        <Border x:Name="BedrockCard"
                Grid.Column="1"
                ClipToBounds="True"
                Cursor="Hand"
                RenderTransformOrigin="0.5,0.5"
                MouseEnter="BedrockCard_MouseEnter"
                MouseLeave="AnyCard_MouseLeave"
                MouseLeftButtonUp="BedrockCard_Click">
            <Border.RenderTransform>
                <ScaleTransform x:Name="BedrockCardScale"/>
            </Border.RenderTransform>

            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/wallpaper_bedrock.png"
                            Stretch="UniformToFill"
                            AlignmentX="Center"
                            AlignmentY="Center"/>
            </Border.Background>

            <Grid>
                <!-- Stronger atmospheric overlay for the bright Bedrock wallpaper -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#660F0F13" Offset="0.0"/>
                            <GradientStop Color="#EE0F0F13" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Edition label badge -->
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="40,36,0,0"
                        Background="#3300B4FF"
                        BorderBrush="#5500B4FF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,4">
                    <TextBlock Text="BEDROCK EDITION"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#00B4FF"/>
                </Border>

                <!-- Main content pinned to bottom-left -->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Margin="40,0,40,56">

                    <TextBlock Text="Bedrock Edition"
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Cross-play. RTX ray tracing. Xbox Live.&#x0a;Play with anyone, on any device."
                               FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                               FontSize="14"
                               FontWeight="Regular"
                               Foreground="#A0A0A5"
                               TextWrapping="Wrap"
                               Margin="0,0,0,28"/>

                    <!-- Feature chips -->
                    <WrapPanel Margin="0,0,0,32">
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="Cross-Platform" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="RTX Ray Tracing" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="10,4" Margin="0,0,8,8">
                            <TextBlock Text="Xbox Live" FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                                       FontSize="11" Foreground="#CCFFFFFF"/>
                        </Border>
                    </WrapPanel>

                    <Button x:Name="BtnSelectBedrock"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="Select Bedrock Edition"
                            Width="220"
                            Height="44"
                            HorizontalAlignment="Left"
                            FontSize="14"
                            Click="BedrockCard_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top bar: Anchor logo + skip link -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2"
              VerticalAlignment="Top" Height="56"
              IsHitTestVisible="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CC0F0F13" Offset="0"/>
                    <GradientStop Color="#000F0F13" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Logo -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="28,0,0,0">
                <Image Source="pack://application:,,,/Assets/AnchorLauncherIcon.png"
                       Width="22" Height="22"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,10,0"/>
                <TextBlock Text="Anchor Launcher"
                           FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Step indicator -->
            <TextBlock Text="Step 1 of 1 — Choose your edition"
                       FontFamily="Inter, Segoe UI Variable Display, Segoe UI"
                       FontSize="12"
                       Foreground="#55555A"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>

    </Grid>
</Window>
