<Window x:Class="AnchorLauncher.Views.Auth.ElyLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0F0F13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="440" Height="460"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="46" Background="{StaticResource Surface1Brush}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="18" Height="18" CornerRadius="9" Background="#00B4FF" Margin="0,0,8,0">
                        <TextBlock Text="e" FontSize="10" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                    </Border>
                    <TextBlock Text="{Binding [el_title], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                        Click="BtnCancel_Click" ToolTip="Cancel">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="13" Height="13" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,20,24,0">
                <TextBlock Text="{Binding [el_email], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource AnchorTextBoxStyle}" Height="40"
                         Foreground="#FFFFFF" CaretBrush="#FFFFFF"
                         Text="{Binding ElyUsername, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{Binding [el_password], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,14,0,6"/>
                <PasswordBox x:Name="ElyPasswordBox" Style="{StaticResource AnchorPasswordBoxStyle}"
                             Height="40" KeyDown="ElyPassword_KeyDown"/>

                <StackPanel Visibility="{Binding IsTwoFactorRequired, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding [el_2fa], Source={x:Static loc:Loc.I}}"
                               FontFamily="{StaticResource PrimaryFont}" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDisabledBrush}" Margin="0,14,0,6"/>
                    <TextBox Style="{StaticResource AnchorTextBoxStyle}" Height="40"
                             Foreground="#FFFFFF" CaretBrush="#FFFFFF"
                             Text="{Binding ElyTwoFactor, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <TextBlock Text="{Binding ElyError}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="11"
                           Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>

                <ProgressBar Style="{StaticResource AnchorProgressBarStyle}"
                             IsIndeterminate="True" Height="2" Margin="0,12,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="{Binding [ci_cancel], Source={x:Static loc:Loc.I}}" Style="{StaticResource GhostButtonStyle}"
                            Height="38" Padding="20,0" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                    <Button Content="{Binding [el_signin], Source={x:Static loc:Loc.I}}" Style="{StaticResource PrimaryButtonStyle}"
                            Height="38" Padding="24,0" Click="ElySignIn_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
