<UserControl x:Class="AnchorLauncher.Views.Skins.SkinViewer3D"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="True"
             Cursor="SizeWE">
    <Grid x:Name="Root">
        <!-- Dark gradient backdrop -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#18181C" Offset="0"/>
                <GradientStop Color="#0F0F13" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Viewport3D x:Name="Viewport">
            <Viewport3D.Camera>
                <PerspectiveCamera Position="0,16,64"
                                   LookDirection="0,0,-1"
                                   UpDirection="0,1,0"
                                   FieldOfView="40"/>
            </Viewport3D.Camera>

            <!-- Lighting for depth -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup>
                        <AmbientLight Color="#9A9A9A"/>
                        <DirectionalLight Color="#C8C8C8" Direction="-0.5,-0.6,-1"/>
                        <DirectionalLight Color="#3C3C3C" Direction="0.6,0.2,1"/>
                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!-- Player model — content + rotation assigned in code-behind -->
            <ModelVisual3D x:Name="ModelHost"/>
        </Viewport3D>

        <!-- Soft floor shadow below the feet -->
        <Ellipse Width="150" Height="34" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                 Margin="0,0,0,40" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#88000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
                <BlurEffect Radius="10"/>
            </Ellipse.Effect>
        </Ellipse>
    </Grid>
</UserControl>
