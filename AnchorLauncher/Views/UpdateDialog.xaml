<Window x:Class="AnchorLauncher.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:AnchorLauncher.Services.Platform"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="Manual" Width="460" Height="420"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Rounded accent progress bar -->
        <Style x:Key="UpdateProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="4" Background="{StaticResource Surface2Brush}" ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="4"
                                        Background="{StaticResource AccentBrush}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource Surface2Brush}" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="34" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- drag / close -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                        Click="Later_Click">
                    <Path Data="M 7,7 L 21,21 M 21,7 L 7,21" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5" StrokeEndLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- body -->
            <StackPanel Grid.Row="1" Margin="34,4,34,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="46" Height="46" CornerRadius="12" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF4500" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <Image Source="/Assets/AnchorLauncherIcon.png" Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding [upd_title], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="VersionText" FontFamily="{StaticResource PrimaryFont}" FontSize="13"
                                   FontWeight="SemiBold" Foreground="{StaticResource AccentHoverBrush}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding [upd_sub], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="13.5" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,0" LineHeight="20"/>
                <TextBlock x:Name="CurrentText" FontFamily="{StaticResource PrimaryFont}" FontSize="12"
                           Foreground="{StaticResource TextDisabledBrush}" Margin="0,6,0,0"/>

                <!-- release notes -->
                <Border Background="{StaticResource Surface1Brush}" CornerRadius="8" Margin="0,14,0,0"
                        Padding="14,11" MaxHeight="120">
                    <ScrollViewer Style="{StaticResource AnchorScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="NotesText" FontFamily="{StaticResource PrimaryFont}" FontSize="12.5"
                                   TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18"/>
                    </ScrollViewer>
                </Border>

                <!-- download progress (hidden until updating) -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,18,0,0">
                    <ProgressBar x:Name="Bar" Style="{StaticResource UpdateProgress}" Minimum="0" Maximum="100"/>
                    <Grid Margin="0,9,0,0">
                        <TextBlock x:Name="StatusText" Text="{Binding [upd_downloading], Source={x:Static loc:Loc.I}}"
                                   FontFamily="{StaticResource PrimaryFont}" FontSize="12.5"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="PctText" Text="0%" FontFamily="{StaticResource PrimaryFont}" FontSize="12.5"
                                   FontWeight="SemiBold" Foreground="{StaticResource AccentHoverBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <!-- failure (hidden until needed) -->
                <TextBlock x:Name="FailText" Visibility="Collapsed" Margin="0,16,0,0"
                           Text="{Binding [upd_failed], Source={x:Static loc:Loc.I}}"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="12.5" TextWrapping="Wrap"
                           Foreground="{StaticResource ErrorBrush}"/>
            </StackPanel>

            <!-- footer -->
            <Border Grid.Row="2" Padding="34,16,34,22">
                <StackPanel x:Name="PromptButtons" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding [upd_later], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource GhostButtonStyle}" Height="38" Padding="20,0" Margin="0,0,10,0"
                            Click="Later_Click"/>
                    <Button x:Name="UpdateButton" Content="{Binding [upd_now], Source={x:Static loc:Loc.I}}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="38" Padding="22,0"
                            Click="UpdateNow_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
